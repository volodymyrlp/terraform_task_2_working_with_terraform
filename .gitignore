# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Generated archive (storage blob source)
content.zip

# Crash log files
crash.log
crash.*.log

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# CLI override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
